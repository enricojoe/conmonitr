# Address the backend HTTP/WS server listens on
CONMONITR_ADDR=:8081
# Optional: override the Docker engine socket/host
# DOCKER_HOST=unix:///var/run/docker.sock

# Login credentials (no database — stored in env)
# Generate a bcrypt hash: htpasswd -bnBC 10 "" yourpassword | tr -d ':\n'
CONMONITR_USER=admin
CONMONITR_PASSWORD_HASH=

# Secret used to sign JWT tokens — use a long random string in production
CONMONITR_JWT_SECRET=

# Allowed CORS origin — set to the frontend's URL in production
CONMONITR_ORIGIN=http://localhost:5174
